#calcualtor


num1 = float(input("Enter Number 1: "))
num2 = float(input("Enter Number 2: "))
op = input("Enter operation: ")
result = None

def calculator():
    if op == "+":
        result = num1 + num2
    elif op == "-":
        result = num1 - num2
    elif op == "*":
        result = num1 * num2
    elif op == "/":
        if num2 != 0:
            result = num1 / num2
        else:
            print("Error: Cannot divide by zero")
    else:
        result = "Invalid operation"
    print(f"Result: {result}")



