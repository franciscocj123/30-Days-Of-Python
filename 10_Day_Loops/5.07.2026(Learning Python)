#Use for loop to iterate from 0 to 100 and print the sum of all evens and the sum of all odds.
total_even = 0
total_odd = 0
for num in range(100+1):
    if num % 2 == 0:
        total_even += num
    elif num % 2 != 0:
        total_odd += num
print(f"Total Even: {total_even}\nTotal odd: {total_odd}")

